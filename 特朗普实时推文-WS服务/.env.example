# ============================================================
# 特朗普实时推文-WS服务  环境变量示例
# 复制为 .env 后按需修改。最少只需要 ADMIN_PASSWORD。
# ============================================================

# ---- 服务端口 ----
PORT=8787

# ---- 管理后台密码 ----
# 进 /admin 用。留空则用内置默认 chuankangkk。
# 生产强烈建议盖一个长随机串：openssl rand -hex 32
ADMIN_PASSWORD=

# ---- SQLite 数据文件 ----
DB_FILE=./data/state.db

# ---- 数据源：trumpstruth.org RSS（默认开启，公开稳定） ----
SOURCE_RSS_ENABLED=true
SOURCE_RSS_URL=https://www.trumpstruth.org/feed
SOURCE_RSS_INTERVAL_MS=10000
SOURCE_RSS_JITTER_PCT=20

# ---- 数据源：Truth Social 一手 API（默认关闭） ----
# 沙箱环境测试到的是 Cloudflare 403 拦截；
# 你的香港服务器上可能可以直连。打开后会和 RSS 并行抓，命中最快源。
SOURCE_TRUTH_ENABLED=false
SOURCE_TRUTH_ACCOUNT_ID=107780257626128497
SOURCE_TRUTH_BEARER=
SOURCE_TRUTH_INTERVAL_MS=3000

# ---- HTTP 代理（可选） ----
# 例：http://127.0.0.1:7890 ；留空走直连
HTTPS_PROXY=

# ---- 翻译：Groq（推荐主供者，免费） ----
# 从 https://console.groq.com/keys 拿，免费额度每天 14400 请求 ≫ Trump 发帖速度
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# 翻译总开关：false 时不翻译，WS 推送 translated 为空串
TRANSLATE_ENABLED=true

# ---- PushPlus 微信推送（保留与 WS 并行） ----
PUSH_ENABLED=true
PUSHPLUS_TOKEN=
PUSHPLUS_TOPIC=trump
PUSHPLUS_API=http://www.pushplus.plus/send

# ---- 历史缓存 ----
HISTORY_LIMIT=200
